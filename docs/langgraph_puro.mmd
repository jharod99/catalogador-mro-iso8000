        decision_maker["decision_maker\ndecision_maker_node(state)"]
        decision_maker --> route_decision{"route_decision()\nestado_global == Alta?"}

        route_decision -->|"Sí\nAlta confianza"| generator
        route_decision -->|"No\nAmbigüedad o Baja"| END_AMB(["__end__\npregunta aclaratoria\no rechazado"])

        generator["generator\ngenerator_node(state)"]
        generator -->|"add_edge fija"| END_OK(["__end__\ndescripción ISO 8000 generada"])
    end

